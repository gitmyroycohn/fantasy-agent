# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── CBS Sports session cookie ──────────────────────────────────────────────
# How to get it:
#   1. Log into cbssports.com in Chrome
#   2. Open DevTools (F12) → Network tab
#   3. Navigate to one of your fantasy league pages
#   4. Click any request to cbssports.com → Headers → Request Headers
#   5. Copy the entire value of the "Cookie:" header
#   6. Paste it below (one long line, no line breaks)
#
# The cookie typically lasts 30–90 days before you need to refresh it.

CBS_COOKIE=your_full_cookie_header_value_here
