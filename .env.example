# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── CBS Sports session cookie ──────────────────────────────────────────────
# How to get it:
#   1. Log into cbssports.com in Chrome
#   2. Open DevTools (F12) -> Network tab
#   3. Navigate to one of your fantasy league pages
#   4. Click any request to cbssports.com -> Headers -> Request Headers
#   5. Copy the entire value of the "Cookie:" header
#   6. Paste it below (one long line, no line breaks)
#
# The cookie typically lasts 30-90 days before you need to refresh it.

CBS_COOKIE=your_full_cookie_header_value_here

# ── FantasyPros API key (ENH 5) ────────────────────────────────────────────
# Used for ROS projections, ECR rankings, closer depth charts, and daily lineups.
# Get a key at: https://www.fantasypros.com/api/
# Leave blank to run without FP enrichment (graceful degradation -- all other
# analysis still works; waiver/drop/trade scoring falls back to MLB Stats API
# and Savant xStats only).
#
# In GitHub Actions this is read from the FANTASYPROS_API_KEY secret -- you
# do NOT need to commit this file with the real key.

FANTASYPROS_API_KEY=your_fantasypros_api_key_here
